# -----------------------------------------------------------------------------
# 툴체인 및 플래그 설정
# -----------------------------------------------------------------------------
BUILD_DIR = build

CC      = riscv32-unknown-elf-gcc
#CFLAGS  = -march=rv32gcv_zba -I./hal -I./lib -g
#ASFLAGS = -march=rv32gcv_zba -I./hal
CFLAGS  = -march=rv32gcv -I./hal -I./lib -g
ASFLAGS = -march=rv32gcv -I./hal


LDFLAGS = -lm
TARGET  = $(BUILD_DIR)/rvv_app

# hal_test용 타겟 실행 파일명 추가
HAL_TEST_TARGET = $(BUILD_DIR)/hal_test_app

TOOL_PATH   := $(HOME)/toolchains/riscv32/bin
TOOL_PREFIX := $(TOOL_PATH)/riscv32-unknown-elf

CC          := $(TOOL_PREFIX)-gcc
C++         := $(TOOL_PREFIX)-g++
OBJDUMP     := $(TOOL_PREFIX)-objdump
OBJCOPY     := $(TOOL_PREFIX)-objcopy
AR          := $(TOOL_PREFIX)-ar
AS          := $(TOOL_PREFIX)-as
LD          := $(TOOL_PREFIX)-ld

# qemu
QEMU        := $(TOOL_PATH)/qemu-riscv32

# -----------------------------------------------------------------------------
# 소스 파일 및 오브젝트 파일 정의
# -----------------------------------------------------------------------------
# 기본 빌드용 소스
C_SRCS   = app/main.c lib/rvv_math.c
ASM_SRCS = hal/hal_rvv_math.S

# hal_test 빌드용 소스 (app/main.c 제외, hal/hal_rvv_test.c 포함)
HAL_TEST_C_SRCS = hal/hal_rvv_test.c lib/rvv_math.c

# .c 와 .S 확장자를 .o 로 변환하여 오브젝트 파일 목록 생성
C_OBJS   = $(patsubst %.c, $(BUILD_DIR)/%.o, $(C_SRCS))
ASM_OBJS = $(patsubst %.S, $(BUILD_DIR)/%.o, $(ASM_SRCS))
OBJS     = $(C_OBJS) $(ASM_OBJS)

# hal_test용 오브젝트 파일 목록 생성
HAL_TEST_C_OBJS = $(patsubst %.c, $(BUILD_DIR)/%.o, $(HAL_TEST_C_SRCS))
HAL_TEST_OBJS   = $(HAL_TEST_C_OBJS) $(ASM_OBJS)

# -----------------------------------------------------------------------------
# 빌드 규칙
# -----------------------------------------------------------------------------
all: $(TARGET)

# 1. 기본 앱 링킹 규칙
$(TARGET): $(OBJS)
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)
	@echo "========================================================"
	@echo " Build Complete: $@"
	@echo "========================================================"

# 1-1. hal_test 앱 링킹 규칙 추가
hal_test: $(HAL_TEST_TARGET)

$(HAL_TEST_TARGET): $(HAL_TEST_OBJS)
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)
	@echo "========================================================"
	@echo " HAL Test Build Complete: $@"
	@echo "========================================================"

# 2. C 소스 컴파일 규칙
$(BUILD_DIR)/%.o: %.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@
	@echo " Compiled C: $< -> $@"

# 3. 어셈블리 소스 컴파일 규칙
$(BUILD_DIR)/%.o: %.S
	@mkdir -p $(dir $@)
	$(CC) $(ASFLAGS) -c $< -o $@
	@echo " Compiled ASM: $< -> $@"

# 기본 앱 실행
run: $(TARGET)
	@echo "Ctrl-A C for QEMU console, then quit to exit"
	$(QEMU) -cpu rv32,v=true,zba=true,vlen=128 $(TARGET)

# hal_test 앱 실행 추가
run_hal_test: hal_test
	@echo "Running HAL Test on QEMU... (Ctrl-A C for QEMU console, then quit to exit)"
	$(QEMU) -cpu rv32,v=true,zba=true,vlen=128 $(HAL_TEST_TARGET)

# 4. 클린업 규칙
clean:
	rm -rf $(BUILD_DIR)